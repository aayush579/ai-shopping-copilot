# Ignore everything by default
*
# Except the following files and directories needed for the project
!/.gitignore
!/.env.local
!/.env
!README.md
!package.json
!package-lock.json
!tsconfig.json
!next.config.ts
!postcss.config.mjs
!eslint.config.mjs
!src/
!public/
!next-env.d.ts
!*.md
# Explicitly ignore build artifacts and dependencies
node_modules/
.next/
out/
build/
coverage/
.vercel/
.env*
